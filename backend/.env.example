# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# Security - Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_generate_random_string

# API key that the frontend must send in the X-API-Key header.
# Leave blank to disable authentication (development only).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=

# Comma-separated list of origins allowed by CORS.
# Leave blank to allow all origins (development only).
# Example: https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS=

# Enable debug mode (true/false). Must be false in production.
FLASK_DEBUG=false

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql://emerabooks:changeme@localhost:5433/emerabooks

# Supabase JWT Secret (from Supabase dashboard > Settings > API > JWT Secret)
# Required for verifying frontend auth tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Stripe billing ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs created in Stripe dashboard for the two plans
STRIPE_PRICE_STARTER=price_xxx_starter_199_aed_monthly
STRIPE_PRICE_PRO=price_xxx_pro_999_aed_monthly
# Where to redirect after Checkout completes / cancels
STRIPE_SUCCESS_URL=https://your-app.com/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://your-app.com/pricing?canceled=1
# Optional: where to send users back to after the Customer Portal
STRIPE_PORTAL_RETURN_URL=https://your-app.com/pricing
# Set to false to disable subscription enforcement (e.g., during local dev before
# you configure Stripe). Default: true.
BILLING_ENFORCED=true
